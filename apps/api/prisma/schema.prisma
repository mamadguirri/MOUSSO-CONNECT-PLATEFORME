generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  phone        String         @unique
  passwordHash String?
  name         String
  role         Role           @default(CLIENT)
  accountType  AccountType    @default(FREE)
  quartierId   String?
  quartier     Quartier?      @relation(fields: [quartierId], references: [id])
  isActive     Boolean        @default(true)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  provider     Provider?
  tokens        RefreshToken[]
  bookings      Booking[]        @relation("ClientBookings")
  reviews       Review[]         @relation("ClientReviews")
  conversations Conversation[]   @relation("ClientConversations")
  purchases     FormationPurchase[]
  notifications Notification[]
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum AccountType {
  FREE
  PROVIDER
}

model Provider {
  id             String            @id @default(uuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id])
  bio            String?
  avatarUrl      String?
  whatsappNumber String
  latitude       Float?
  longitude      Float?
  isVerified     Boolean           @default(false)
  isSuspended    Boolean           @default(false)
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  services       ProviderService[]
  bookings       Booking[]
  reviews        Review[]
  conversations  Conversation[]
  formations     Formation[]
}

model Category {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  iconName  String
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  services  ProviderService[]
}

model ProviderService {
  id          String   @id @default(uuid())
  providerId  String
  categoryId  String
  description String?
  priceRange  String?
  provider    Provider @relation(fields: [providerId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  photos      ServicePhoto[]
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([providerId, categoryId])
}

model ServicePhoto {
  id        String          @id @default(uuid())
  serviceId String
  url       String
  order     Int             @default(0)
  service   ProviderService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

model Photo {
  id         String   @id @default(uuid())
  providerId String
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Quartier {
  id        String @id @default(uuid())
  name      String
  ville     String @default("Bamako")
  region    String @default("Bamako")
  latitude  Float?
  longitude Float?
  users     User[]
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  code      String
  purpose   OtpPurpose @default(LOGIN)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum OtpPurpose {
  LOGIN
  RESET_PASSWORD
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Booking {
  id              String          @id @default(uuid())
  clientId        String
  providerId      String
  serviceId       String
  client          User            @relation("ClientBookings", fields: [clientId], references: [id])
  provider        Provider        @relation(fields: [providerId], references: [id])
  service         ProviderService @relation(fields: [serviceId], references: [id])
  status          BookingStatus   @default(PENDING)
  requestedDate   DateTime
  requestedTime   String
  note            String?
  clientPhone     String
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

// ===== AVIS ET NOTATIONS =====

model Review {
  id         String   @id @default(uuid())
  clientId   String
  providerId String
  rating     Int      // 1-5 étoiles
  comment    String?
  client     User     @relation("ClientReviews", fields: [clientId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clientId, providerId])
}

// ===== MESSAGERIE =====

model Conversation {
  id           String    @id @default(uuid())
  clientId     String
  providerId   String
  client       User      @relation("ClientConversations", fields: [clientId], references: [id])
  provider     Provider  @relation(fields: [providerId], references: [id])
  lastMessageAt DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]

  @@unique([clientId, providerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  type           MessageType  @default(TEXT)
  content        String?
  fileUrl        String?
  fileName       String?
  duration       Int?         // durée du vocal en secondes
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  FILE
}

// ===== FORMATIONS =====

model Formation {
  id          String   @id @default(uuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  title       String
  description String?
  price       Int      // Prix en FCFA
  coverUrl    String?
  isPublished Boolean  @default(false)
  modules     FormationModule[]
  purchases   FormationPurchase[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormationModule {
  id           String   @id @default(uuid())
  formationId  String
  formation    Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  order        Int      @default(0)
  medias       FormationMedia[]
  createdAt    DateTime @default(now())
}

model FormationMedia {
  id        String   @id @default(uuid())
  moduleId  String
  module    FormationModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type      MediaType @default(IMAGE)
  url       String
  name      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model FormationPurchase {
  id           String    @id @default(uuid())
  clientId     String
  formationId  String
  client       User      @relation(fields: [clientId], references: [id])
  formation    Formation @relation(fields: [formationId], references: [id])
  pricePaid    Int
  createdAt    DateTime  @default(now())

  @@unique([clientId, formationId])
}

// ===== NOTIFICATIONS =====

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  data      Json?            // données supplémentaires (bookingId, formationId, etc.)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  BOOKING_NEW        // Prestataire: nouvelle réservation
  BOOKING_ACCEPTED   // Client: réservation acceptée
  BOOKING_REJECTED   // Client: réservation refusée
  BOOKING_COMPLETED  // Client: réservation terminée
  BOOKING_CANCELLED  // Prestataire: réservation annulée
  FORMATION_PURCHASE // Prestataire: quelqu'un a acheté sa formation
  REVIEW_NEW         // Prestataire: nouvel avis
  PROVIDER_VERIFIED  // Prestataire: profil vérifié
  PROVIDER_SUSPENDED // Prestataire: profil suspendu
  SYSTEM             // Notification système
}
