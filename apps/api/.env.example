# ===========================================
# Musso Connect API - Variables d'environnement
# ===========================================
# Copier ce fichier : cp .env.example .env

# Base de donnees PostgreSQL
DATABASE_URL="postgresql://musso:musso_dev_password@localhost:5432/musso_connect"

# JWT (CHANGER en production !)
JWT_SECRET="dev-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production"

# Serveur
PORT=4000
NODE_ENV=development
ALLOWED_ORIGIN="http://localhost:3000"
ADMIN_PHONE="+22300000000"

# Twilio SMS (optionnel en dev - les OTP s'affichent dans la console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cloudflare R2 (optionnel en dev - les fichiers sont sauvegardes localement)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=musso-connect
R2_PUBLIC_URL=
